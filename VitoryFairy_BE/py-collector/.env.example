# --- S3 (bronze landing) ---
COLLECTOR_S3_BUCKET=kbo-bronze-local
COLLECTOR_S3_REGION=ap-northeast-2
# LocalStack endpoint for local dev; leave blank for real AWS
COLLECTOR_S3_ENDPOINT=http://localhost:4566
COLLECTOR_S3_PATH_STYLE=true
# static creds are fine for LocalStack
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Naver sports source ---
COLLECTOR_NAVER_BASE_URL=https://api-gw.sports.naver.com
COLLECTOR_NAVER_REFERER=https://m.sports.naver.com/
COLLECTOR_SCHEDULE_URL_TEMPLATE={base}/schedule/games?fields=basic,statusNum,statusInfo&upperCategoryId=kbaseball&fromDate={date}&toDate={date}
COLLECTOR_RESULT_URL_TEMPLATE={base}/schedule/games/{gameId}
COLLECTOR_RELAY_URL_TEMPLATE={base}/schedule/games/{gameId}/relay?inning={inning}

# --- community ---
COLLECTOR_TARGETS_FILE=config/targets.yaml
COLLECTOR_TOP_COMMENTS=20
COLLECTOR_FETCH_DELAY_MS=800
COLLECTOR_LIST_PAGES=1
# REQUIRED: salt for masking comment authors (do not commit the real value)
COLLECTOR_PII_SALT=change-me-in-real-env

# --- retry / local paths ---
RETRY_ATTEMPTS=3
RETRY_BACKOFF_BASE=0.5
HTTP_TIMEOUT_S=10
LOG_DIR=./logs
JOURNAL_DIR=./journal

APP_NAME=VictoryFairy AI
APP_VERSION=0.1.0
DEBUG=false
API_PREFIX=/api

# pipeline(run_validation) — S3 게시글 in/out. 값은 절대 커밋하지 말 것(플레이스홀더만).
S3_BUCKET=
AWS_REGION=ap-northeast-2
# S3 접근 엔드포인트 override(선택). 비우면 기본 AWS 리전 엔드포인트.
# VPC 게이트웨이 엔드포인트/MinIO 등 S3 호환 스토리지에 붙일 때만 지정(예: http://minio:9000).
S3_ENDPOINT_URL=
# boto3 기본 자격증명 체인(PIPE-S3IO-14). 임시 STS 사용 시 AWS_SESSION_TOKEN도 채운다.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

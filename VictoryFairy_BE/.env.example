# ─────────────────────────────────────────────────────────────
# VictoryFairy 환경변수 템플릿
# 사용법: cp .env.example .env 후 값을 채운다. .env 는 절대 커밋하지 않는다(.gitignore 처리됨).
# 이 파일에는 실제 시크릿을 넣지 말 것 — 형식/예시값만 유지한다.
# ─────────────────────────────────────────────────────────────

# ── 프로파일 ──
# dev: LogEmailSender(메일 mock, 인증번호는 로그로만 출력) / prod: SmtpEmailSender(Mailjet 실발송)
SPRING_PROFILES_ACTIVE=dev
COMPOSE_PROFILES=${SPRING_PROFILES_ACTIVE}

# ── DB (dev=로컬 MySQL 컨테이너 / prod=AWS RDS) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=victory-fairy
DB_USERNAME=your-db-username
DB_PASSWORD=change-me

# ── JWT ── 32바이트 이상 랜덤 문자열 (예: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-32byte-plus-random-value

# ── Redis (이메일 인증코드 저장) ── 로컬 기본값 사용 시 생략 가능
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────
# 이메일 발송 (Mailjet SMTP 릴레이) — prod 프로파일에서만 실제 발송됨
#   - HOST/PORT는 docker-compose.prod.yml 에 Mailjet 고정값(in-v3.mailjet.com:587)으로 하드코딩됨.
#     아래 두 시크릿만 .env 로 주입한다.
#   - MAIL_USERNAME = Mailjet API Key   (Account settings → API Key Management)
#   - MAIL_PASSWORD = Mailjet Secret Key
#   - 발신 도메인 victoryfairy.com 은 Mailjet 콘솔에서 SPF/DKIM 인증을 완료해야
#     네이버·다음 등 국내 수신함 도달률이 확보된다(미인증 시 스팸함 직행 위험).
# ─────────────────────────────────────────────────────────────
MAIL_USERNAME=your-mailjet-api-key
MAIL_PASSWORD=your-mailjet-secret-key
MAIL_FROM=no-reply@victoryfairy.com

# ── 배포용 GHCR 이미지 (docker-compose.prod.yml) ──
# IMAGE_PREFIX=ghcr.io/parkjaehwan-906
# IMAGE_TAG=latest
